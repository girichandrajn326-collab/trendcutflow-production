# Supabase — authentication and database (required)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Groq — Whisper-large-v3 audio transcription (Edge Function secret)
GROQ_API_KEY=

# OpenAI — GPT-4o-mini viral clip detection (Edge Function secret)
OPENAI_API_KEY=

# Razorpay — payment processing (add to .env for live payments)
VITE_RAZORPAY_KEY_ID=

# YouTube Data API — OAuth2 for Shorts publishing (Edge Function secrets)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
